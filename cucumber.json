{
    "default": {
        "formatOptions": {
            "snippetInterface": "async-await"
        },
        "paths": [
            "src/tests/features/*.feature"
        
        ],
        "publishQuiet": true,
        "dryRun": false,
        "require": [
            "src/tests/steps/*.ts",
            "src/tests/hooks/*.ts"
        ],
        "requireModule": [
            "ts-node/register"
        ],
        "format": [
            "html:cucumber-report.html"
        ]
    }
}
